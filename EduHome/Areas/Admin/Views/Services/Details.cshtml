@model Service
<div class="col-8">
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Create Services</h5>
        </div>
        <div class="card-body">
            <div class="mb-3 form-group">
                <h1>@Model.Name</h1>
            </div>
            <div class="mb-3 form-group">
                <h3>@Model.Description</h3>
            </div>
        </div>
    </div>
</div>
