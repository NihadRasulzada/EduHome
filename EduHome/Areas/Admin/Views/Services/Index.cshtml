@model List<Service>
<div class="card">
    <div class="card-header" style="display:flex;justify-content:space-between">
        <div><h2>Services</h2></div>
        <div>
            <a asp-area="Admin" asp-controller="Services" asp-action="Create" class="btn rounded-pill btn-warning text-white" style="margin-right:10px">Create</a>
        </div>
    </div>
    <div class="table-responsive text-nowrap">
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody class="table-border-bottom-0">
                @foreach (Service item in Model)
                {
                    <tr>
                        <td><i class="fab fa-angular fa-lg text-danger me-3"></i> <strong>@item.Name</strong></td>
                        @if (item.isDeactive)
                        {
                            <td><span class="badge bg-label-danger me-1">Deactive</span></td>
                        }
                        else
                        {
                            <td><span class="badge bg-label-primary me-1">Active</span></td>
                        }
                        <td style="text-align:end; gap:normal">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn rounded-pill btn-warning text-white">Detail</a>
                            <a asp-action="Update" asp-route-id="@item.Id" class="btn rounded-pill btn-primary text-white">Update</a>
                            @if (item.isDeactive)
                            {
                                <a asp-action="Activity" asp-route-id="@item.Id" class="btn rounded-pill btn-success text-white">Activate</a>
                            }
                            else
                            {
                                <a asp-action="Activity" asp-route-id="@item.Id" class="btn rounded-pill btn-danger text-white">DeActivate</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>