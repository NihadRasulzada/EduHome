@model ResetPasswordVM
<div class="col-8">
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0">ResetPassword</h5>
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        </div>
        <div class="card-body">
            <form method="post">
                <div style="margin-bottom:15px !important">
                    <input asp-for="Password" placeholder="Password" style="margin-bottom:0px">
                    <span asp-validation-for="Password" style="color:red; margin-left:10px"></span>
                </div>
                <div style="margin-bottom:15px !important">
                    <input asp-for="CheckPassword" placeholder="CheckPassword" style="margin-bottom:0px">
                    <span asp-validation-for="CheckPassword" style="color:red; margin-left:10px"></span>
                </div>
                <button type="submit" class="btn btn-primary">Send</button>
            </form>
        </div>
    </div>
</div>

@section Scripts{
    <partial name="_ValidationScriptsPartial" />
}